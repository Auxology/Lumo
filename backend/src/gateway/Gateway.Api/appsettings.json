{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Redis": {
    "ConnectionString": "localhost:6379",
    "Password": ""
  },
  "ReverseProxy": {
    "Routes": {
      "auth-api-route": {
        "ClusterId": "auth-api-cluster",
        "RateLimiterPolicy": "sliding",
        "Match": { "Path": "/api/{**catch-all}" }
      }
    },
    "Clusters": {
      "auth-api-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://auth.api:5100"
          }
        }
      }
    }
  }
}
